---
import Layout from "@/layouts/Layout.astro";
import HeadPost from "@/components/HeadPost.astro";
import { Icon } from "astro-icon/components";
import { getAbsoluteLocaleUrl } from "astro:i18n";

interface Layout {
  title: string;
  description: string;
  lang?: string;
  image?: string;
  author?: string;
  canonical?: string;
  publised?: Date;
  readMinTime?: number;
  ogType?: "website" | "article" | "profile";
}

const {
  id,
  title,
  description,
  image,
  canonical,
  readMinTime,
  author,
  published,
  ogType,
} = Astro.props;

const lang = Astro.currentLocale || "en";
const projectsUrl = getAbsoluteLocaleUrl(lang, "/projects");
---

<Layout
  title={title}
  description={description}
  image={image}
  canonical={canonical}
  ogType={ogType}
>
  <main
    class="relative min-h-screen overflow-hidden bg-ui-body transition-colors"
  >
    <!-- Ambient Background Depth -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
      <!-- Orbs -->
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-primary-500/10 rounded-full blur-[120px] opacity-60 mix-blend-screen dark:mix-blend-normal"
      >
      </div>
      <div
        class="absolute top-[20%] right-0 w-[800px] h-[800px] bg-violet-500/5 rounded-full blur-[120px] opacity-40"
      >
      </div>
    </div>

    <section class="relative z-10 mx-auto lg:py-24 py-12 sm:py-16 px-4 sm:px-6">
      <!-- Back Button -->
      <div class="max-w-4xl mx-auto mb-8 sm:mb-12">
        <a
          href={projectsUrl}
          class="inline-flex items-center gap-2 text-typo-secondary hover:text-ui-accent transition-colors duration-300 font-medium group"
        >
          <Icon
            name="tabler:arrow-left"
            class="group-hover:-translate-x-1 transition-transform duration-300"
          />
          Back to projects
        </a>
      </div>

      <article class="max-w-4xl mx-auto">
        <HeadPost
          id={id}
          title={title}
          author={author}
          published={published}
          excerpt={description}
          image={image}
          readTime={readMinTime}
        />

        <div class="mt-8 mb-12 flex flex-col items-center gap-6">
          <slot name="subhead" />
        </div>

        <div
          class="mx-auto max-w-3xl prose prose-lg dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-typo-primary prose-p:text-typo-secondary prose-a:text-ui-accent prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-img:shadow-xl prose-img:w-full prose-img:max-w-full prose-code:before:content-none prose-code:after:content-none prose-code:[:not(pre>code)]:text-ui-accent prose-code:[:not(pre>code)]:bg-ui-accent/10 prose-code:[:not(pre>code)]:px-1.5 prose-code:[:not(pre>code)]:py-0.5 prose-code:[:not(pre>code)]:rounded-md prose-code:[:not(pre>code)]:font-medium prose-pre:p-4 prose-pre:rounded-lg prose-pre:border prose-pre:border-ui-03/50 prose-pre:overflow-x-auto prose-pre:leading-relaxed"
        >
          <slot />
        </div>
      </article>
    </section>
  </main>
</Layout>

<style>
  /* Stars generation using CSS (Simplified for layout) */
  .stars-layer-1,
  .stars-layer-2 {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    animation: star-twinkle 4s ease-in-out infinite;
  }

  .stars-layer-1 {
    background-image: radial-gradient(
        1px 1px at 20px 30px,
        var(--color-primary-300),
        transparent
      ),
      radial-gradient(1px 1px at 40px 70px, var(--color-gray-400), transparent),
      radial-gradient(
        1px 1px at 50px 160px,
        var(--color-primary-400),
        transparent
      ),
      radial-gradient(1px 1px at 90px 40px, var(--color-gray-300), transparent),
      radial-gradient(
        1px 1px at 130px 80px,
        var(--color-primary-300),
        transparent
      ),
      radial-gradient(
        1px 1px at 160px 120px,
        var(--color-gray-400),
        transparent
      );
    background-size: 550px 200px;
    opacity: 0.4;
  }

  .stars-layer-2 {
    background-image: radial-gradient(
        1.5px 1.5px at 100px 150px,
        var(--color-primary-400),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 200px 50px,
        var(--color-violet-400),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 300px 250px,
        var(--color-primary-400),
        transparent
      );
    background-size: 450px 350px;
    animation-delay: 2s;
    opacity: 0.5;
  }

  @keyframes star-twinkle {
    0%,
    100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.1);
    }
  }
</style>
