---
interface Props {
  repositoryURL: string;
}

const { repositoryURL } = Astro.props;
const repoURL = new URL(repositoryURL);
---

<div class="flex flex-wrap justify-center gap-3 mt-4 opacity-90 hover:opacity-100 transition-opacity duration-300">
  <a href={`https://github.com${repoURL.pathname}`} target="_blank" class="hover:scale-105 transition-transform duration-200">
    <img
      alt="Github Stars"
      src={`https://img.shields.io/github/stars${repoURL.pathname}?style=for-the-badge&color=1e293b&labelColor=0f172a`}
      height="28"
    />
  </a>
  <a href={`https://github.com${repoURL.pathname}/issues`} target="_blank" class="hover:scale-105 transition-transform duration-200">
    <img
      alt="Github Issues"
      src={`https://img.shields.io/github/issues${repoURL.pathname}?style=for-the-badge&color=1e293b&labelColor=0f172a`}
      height="28"
    />
  </a>
  <a
    href={`https://github.com${repoURL.pathname}/network/members`}
    target="_blank"
    class="hover:scale-105 transition-transform duration-200"
  >
    <img
      alt="Github Forks"
      src={`https://img.shields.io/github/forks${repoURL.pathname}?style=for-the-badge&color=1e293b&labelColor=0f172a`}
      height="28"
    />
  </a>
  <a href={`https://github.com${repoURL.pathname}/pulls`} target="_blank" class="hover:scale-105 transition-transform duration-200">
    <img
      alt="Github PRs"
      src={`https://img.shields.io/github/issues-pr${repoURL.pathname}?style=for-the-badge&color=1e293b&labelColor=0f172a`}
      height="28"
    />
  </a>
</div>
