---
import { Icon } from "astro-icon/components";
import { loadI18n } from "@/utils/i18n";

interface Props {
  repoUri?: string;
  website?: string;
}

const lang = Astro.currentLocale || "en";
const { repoUri, website } = Astro.props;
const t = await loadI18n({ lang, asset: "pages/project-detail" });
---

<div class="flex flex-wrap justify-center gap-4 w-full">
  {
    repoUri && (
      <a
        href={repoUri}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary rounded-full px-6 py-3 text-base font-medium flex items-center gap-2 shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300"
      >
        <Icon name="tabler:brand-github" class="text-xl" />
        <span>{t("repository")}</span>
      </a>
    )
  }
  {
    website && (
      <a
        href={website}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary rounded-full px-6 py-3 text-base font-medium flex items-center gap-2 shadow-lg shadow-primary-500/20 hover:shadow-primary-500/30 hover:-translate-y-0.5 transition-all duration-300"
      >
        <Icon name="tabler:world" class="text-xl" />
        <span>{t("website")}</span>
      </a>
    )
  }
</div>
