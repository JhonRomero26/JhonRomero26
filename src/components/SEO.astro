---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  lang?: string;
  ogType?: "website" | "article" | "profile";
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  image = "/og.jpg",
  lang = "en",
  ogType = "website",
  noindex = false,
  jsonLd,
} = Astro.props;

const siteUrl = "https://jhonromero.dev";

const getCanonicalURL = (): string => {
  if (canonical) return canonical.startsWith("http") ? canonical : `${siteUrl}${canonical}`;
  const path = Astro.url.pathname;
  return `${siteUrl}${path}`;
};

const canonicalURLStr = getCanonicalURL();

// Compute hreflang alternates
// EN canonical: /path or /projects/x  → ES: /es/path or /es/projects/x
// ES canonical: /es/path              → EN: /path
const pathname = Astro.url.pathname;
const isEs = pathname.startsWith("/es") || lang === "es";
const enPath = isEs ? pathname.replace(/^\/es/, "") || "/" : pathname;
const esPath = isEs ? pathname : `/es${pathname === "/" ? "" : pathname}`;
const enUrl = `${siteUrl}${enPath}`;
const esUrl = `${siteUrl}${esPath}`;

// Default JSON-LD: Person + WebSite for non-article pages
const defaultPersonJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Jhon Alexander Romero Gonzaga",
  url: siteUrl,
  email: "romerogonzaga21@gmail.com",
  jobTitle: "Odoo Developer & Full Stack TypeScript Engineer",
  sameAs: [
    "https://www.linkedin.com/in/jhonromero26/",
    "https://github.com/JhonRomero26",
  ],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Loja",
    addressCountry: "EC",
  },
};

const defaultWebSiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Jhon Romero — Portfolio",
  url: siteUrl,
  description:
    "Portfolio of Jhon Romero, Odoo Developer & Full Stack TypeScript Engineer.",
};

const resolvedJsonLd = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : (ogType === "website"
      ? [defaultPersonJsonLd, defaultWebSiteJsonLd]
      : ogType === "profile"
        ? [defaultPersonJsonLd]
        : []);

const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const imageURL = image.startsWith("http") ? image : new URL(image, Astro.site ?? siteUrl).toString();
---

<meta charset="UTF-8" />
<title>{title}</title>

<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="author" content="Jhon Alexander Romero Gonzaga" />

<link rel="canonical" href={canonicalURLStr} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="es" href={esUrl} />
<link rel="alternate" hreflang="x-default" href={enUrl} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@jhonchinss" />
<meta name="twitter:creator" content="@jhonchinss" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content="Jhon Romero" />
<meta property="og:url" content={canonicalURLStr} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={lang === "es" ? "es_EC" : "en_US"} />
<meta property="og:locale:alternate" content={lang === "es" ? "en_US" : "es_EC"} />

<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={robotsContent} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

{resolvedJsonLd.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify(resolvedJsonLd.length === 1 ? resolvedJsonLd[0] : resolvedJsonLd)} />
)}
