---
import CentralSection from "@/components/CentralSection.astro";
import { loadI18n } from "@/utils/i18n";

const t = await loadI18n({ lang: Astro.currentLocale, asset: "pages/home" });

const pillars = t("about.pillars") as unknown as Array<{
  title: string;
  description: string;
}>;
---

<CentralSection class="section-alt relative overflow-hidden">
  <!-- Decorative warm orb -->
  <div class="warm-orb absolute -top-32 right-1/4 w-96 h-96 -z-10" aria-hidden="true" />

  <span slot="title">
    {t("about.title.normal")}
    <span class="text-ui-accent">{t("about.title.accent")}</span>
  </span>
  <p slot="subtitle">
    {t("about.subtitle")}
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
    {
      pillars.map((pillar, index) => (
        <article
          class="group flex flex-col gap-4 p-6 rounded-2xl bg-ui-body dark:bg-ui-01 border border-ui-02 dark:border-ui-02/50 shadow-sm hover:shadow-lg hover:shadow-primary-700/10 hover:border-primary-700/30 transition-all duration-300"
          style={`animation-delay: ${index * 80}ms`}
        >
          <!-- Accent bar -->
          <div class="w-10 h-[3px] rounded-full bg-gradient-to-r from-primary-600 to-primary-400 group-hover:w-16 transition-all duration-300" aria-hidden="true" />

          <h3 class="text-base sm:text-lg font-bold text-typo-primary leading-snug">
            {pillar.title}
          </h3>

          <p class="text-sm sm:text-base text-typo-secondary leading-relaxed flex-1">
            {pillar.description}
          </p>
        </article>
      ))
    }
  </div>
</CentralSection>
