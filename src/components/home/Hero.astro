---
import Logo from "@/components/Logo.astro";
import Tooltip from "@/components/Tooltip.astro";
import { loadI18n } from "@/utils/i18n";
import { Icon } from "astro-icon/components";
import { getAbsoluteLocaleUrl } from "astro:i18n";

const lang = Astro.currentLocale || "en";
const t = await loadI18n({ lang, asset: "pages/home" });

const socialLinks = [
  {
    name: "Github",
    href: "https://github.com/JhonRomero26",
    icon: "simple-icons:github",
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/jhonromero26/",
    icon: "simple-icons:linkedin",
  },
  {
    name: "CV",
    href: getAbsoluteLocaleUrl(lang, "/cv"),
    icon: "tabler:paperclip",
  },
  {
    name: "Email",
    href: "mailto:romerogonzaga21@gmail.com",
    icon: "tabler:mail",
  },
];
---

<section
  class="hero-section overflow-hidden relative flex items-center justify-center px-4 sm:px-6 lg:px-8 py-12 sm:py-16 w-full min-h-[calc(100dvh-56px)] bg-ui-body transition-colors"
>
  <!-- Starfield Background -->
  <div
    class="hero-stars absolute inset-0 overflow-hidden pointer-events-none"
    aria-hidden="true"
  >
    <!-- Stars Layer 1 - Small stars -->
    <div class="stars-layer-1 absolute inset-0"></div>
    <!-- Stars Layer 2 - Medium stars -->
    <div class="stars-layer-2 absolute inset-0"></div>
    <!-- Stars Layer 3 - Large stars -->
    <div class="stars-layer-3 absolute inset-0"></div>

    <!-- Static ambient glow: no opacity animation to avoid hero flicker -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[min(600px,90vw)] h-[min(600px,90vw)] rounded-full bg-gradient-radial from-ui-accent/12 via-ui-accent/5 to-transparent blur-3xl"
    >
    </div>

    <!-- Accent glows -->
    <div
      class="absolute top-[20%] left-[15%] w-[min(300px,40vw)] h-[min(300px,40vw)] rounded-full bg-violet-500/8 dark:bg-violet-500/10 blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-[20%] right-[15%] w-[min(350px,45vw)] h-[min(350px,45vw)] rounded-full bg-ui-accent/8 dark:bg-ui-accent/15 blur-3xl"
    >
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-ui-body to-transparent z-0"></div>
  </div>

  <!-- Main content -->
  <div
    class="relative z-10 w-full max-w-4xl mx-auto flex flex-col items-center text-center"
  >
    <!-- Logo -->
    <div class="mb-8 sm:mb-10">
      <Logo
        class="animate animate-scale-fade-in animate-duration-1000 w-32 sm:w-40 md:w-48 lg:w-56 h-auto drop-shadow-2xl"
      />
    </div>

    <!-- Text content -->
    <div
      style={{ animationDelay: "200ms" }}
      class="animate animate-blurred-fade-in space-y-6 sm:space-y-8"
    >
      <!-- Name -->
      <div class="space-y-4 sm:space-y-5">
        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold leading-none tracking-tight"
        >
          <span class="block text-ui-primary">Jhon Alexander</span>
          <span class="block text-ui-accent pb-2">Romero Gonzaga</span>
        </h1>

        <!-- Subtitle badge -->
        <div class="flex justify-center">
          <span
            class="inline-block text-sm sm:text-base md:text-lg lg:text-xl font-bold uppercase tracking-widest px-4 sm:px-6 py-2 text-ui-body bg-ui-accent rounded-full shadow-lg shadow-ui-accent/20 border border-ui-accent/20 backdrop-blur-sm"
          >
            {t("hero.subtitle")}
          </span>
        </div>
      </div>

      <!-- Description -->
      <p
        class="text-base sm:text-lg md:text-xl text-typo-secondary max-w-2xl mx-auto leading-relaxed px-4"
      >
        {t("hero.description")}
      </p>
    </div>

    <!-- Availability badge -->
    <div
      style={{ animationDelay: "350ms" }}
      class="animate animate-blurred-fade-in flex justify-center mt-6"
    >
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-500/10 border border-green-500/30 text-green-600 dark:text-green-400 text-sm font-medium">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        {t("hero.availability")}
      </span>
    </div>

    <!-- CTA Buttons -->
    <div
      style={{ animationDelay: "380ms" }}
      class="animate animate-blurred-fade-in flex flex-wrap justify-center gap-3 sm:gap-4 mt-6 sm:mt-8"
    >
      <a
        href="#projects"
        class="btn btn-primary px-6 py-2.5 text-sm sm:text-base font-semibold rounded-full shadow-lg shadow-ui-accent/20"
      >
        {t("hero.projectsCta")}
      </a>
      <a
        href={getAbsoluteLocaleUrl(lang, "/contact")}
        class="btn btn-secondary px-6 py-2.5 text-sm sm:text-base font-semibold rounded-full"
      >
        {t("hero.contactCta")}
      </a>
    </div>

    <!-- Social links -->
    <div
      style={{ animationDelay: "400ms" }}
      class="animate animate-blurred-fade-in flex flex-wrap justify-center gap-4 sm:gap-6 mt-8 sm:mt-10"
    >
      {
        socialLinks.map((link) => (
          <Tooltip direction="bottom">
            <span slot="message">{link.name}</span>
            <a
              href={link.href}
              rel="nofollow noopener noreferrer"
              target={link.href.startsWith("mailto") || link.href.startsWith("/") ? "_self" : "_blank"}
              class="btn btn-secondary btn-icon text-xl sm:text-2xl md:text-3xl size-10 sm:size-12 md:size-14"
              aria-label={link.name}
            >
              <Icon name={link.icon} />
            </a>
          </Tooltip>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Stars generation using CSS */
  .stars-layer-1,
  .stars-layer-2,
  .stars-layer-3 {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    transform: translateZ(0);
    will-change: auto;
  }

  .stars-layer-1 {
    background-image: radial-gradient(
        1px 1px at 20px 30px,
        color-mix(in oklch, var(--color-ui-accent) 55%, transparent),
        transparent
      ),
      radial-gradient(1px 1px at 40px 70px, var(--color-gray-400), transparent),
      radial-gradient(
        1px 1px at 50px 160px,
        color-mix(in oklch, var(--color-ui-accent) 65%, transparent),
        transparent
      ),
      radial-gradient(1px 1px at 90px 40px, var(--color-gray-300), transparent),
      radial-gradient(
        1px 1px at 130px 80px,
        color-mix(in oklch, var(--color-ui-accent) 55%, transparent),
        transparent
      ),
      radial-gradient(
        1px 1px at 160px 120px,
        var(--color-gray-400),
        transparent
      ),
      radial-gradient(
        1px 1px at 200px 50px,
        color-mix(in oklch, var(--color-ui-accent) 65%, transparent),
        transparent
      ),
      radial-gradient(
        1px 1px at 220px 150px,
        var(--color-gray-300),
        transparent
      ),
      radial-gradient(
        1px 1px at 280px 90px,
        color-mix(in oklch, var(--color-ui-accent) 55%, transparent),
        transparent
      ),
      radial-gradient(
        1px 1px at 320px 180px,
        var(--color-gray-400),
        transparent
      ),
      radial-gradient(
        1px 1px at 350px 30px,
        color-mix(in oklch, var(--color-ui-accent) 65%, transparent),
        transparent
      ),
      radial-gradient(
        1px 1px at 400px 130px,
        var(--color-gray-300),
        transparent
      ),
      radial-gradient(
        1px 1px at 450px 60px,
        color-mix(in oklch, var(--color-ui-accent) 55%, transparent),
        transparent
      ),
      radial-gradient(
        1px 1px at 500px 170px,
        var(--color-gray-400),
        transparent
      );
    background-size: 550px 200px;
    opacity: 0.6;
  }

  .stars-layer-2 {
    background-image: radial-gradient(
        1.5px 1.5px at 10px 10px,
        color-mix(in oklch, var(--color-ui-accent) 65%, transparent),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 150px 150px,
        var(--color-violet-400),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 60px 200px,
        color-mix(in oklch, var(--color-ui-accent) 55%, transparent),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 200px 60px,
        var(--color-violet-400),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 300px 250px,
        color-mix(in oklch, var(--color-ui-accent) 65%, transparent),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 400px 100px,
        var(--color-violet-400),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 100px 300px,
        color-mix(in oklch, var(--color-ui-accent) 55%, transparent),
        transparent
      ),
      radial-gradient(
        1.5px 1.5px at 250px 180px,
        var(--color-violet-400),
        transparent
      );
    background-size: 450px 350px;
    opacity: 0.7;
  }

  .stars-layer-3 {
    background-image: radial-gradient(
        2px 2px at 75px 75px,
        color-mix(in oklch, var(--color-ui-accent) 75%, transparent),
        transparent
      ),
      radial-gradient(
        2px 2px at 175px 275px,
        color-mix(in oklch, var(--color-ui-accent) 65%, transparent),
        transparent
      ),
      radial-gradient(
        2px 2px at 350px 150px,
        var(--color-violet-500),
        transparent
      ),
      radial-gradient(
        2px 2px at 250px 50px,
        color-mix(in oklch, var(--color-ui-accent) 75%, transparent),
        transparent
      ),
      radial-gradient(
        2px 2px at 450px 300px,
        var(--color-violet-400),
        transparent
      );
    background-size: 500px 400px;
    opacity: 0.8;
  }

  /* Dark theme - brighter stars */
  :global([data-theme="dark"]) .stars-layer-1 {
    opacity: 0.8;
  }

  :global([data-theme="dark"]) .stars-layer-2 {
    opacity: 0.9;
  }

  :global([data-theme="dark"]) .stars-layer-3 {
    opacity: 1;
  }

  /* Radial gradient helper */
  .bg-gradient-radial {
    background: radial-gradient(
      circle,
      var(--tw-gradient-from),
      var(--tw-gradient-via),
      var(--tw-gradient-to)
    );
  }
</style>
