---
import Layout from "@/layouts/Layout.astro";
import { loadI18n } from "@/utils/i18n";
import { Icon } from "astro-icon/components";

const lang = Astro.currentLocale || "en";
const t = await loadI18n({ lang, asset: "pages/contact" });

const opportunities = t("opportunities.items") as unknown as Array<{
  title: string;
  description: string;
}>;
---

<Layout title={t("title")} description={t("description")} ogType="website">
  <main class="container relative z-10 py-16 sm:py-24 lg:py-32">
    <!-- Heading -->
    <div class="max-w-3xl mx-auto text-center mb-16 sm:mb-20 space-y-4 px-4">
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-tight"
      >
        <span class="text-typo-primary">{t("heading.normal")}</span>
        {" "}
        <span
          class="bg-gradient-to-r from-primary-400 to-violet-400 bg-clip-text text-transparent"
        >
          {t("heading.accent")}
        </span>
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-typo-secondary leading-relaxed max-w-xl mx-auto">
        {t("subtitle")}
      </p>

      <!-- Availability badge -->
      <div class="flex justify-center pt-2">
        <span
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/30 text-green-600 dark:text-green-400 text-sm font-medium"
        >
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse" aria-hidden="true"></span>
          {t("availability.status")}
        </span>
      </div>
      <p class="text-sm text-typo-secondary">
        {t("availability.types")}
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-14 px-4">
      <!-- Contact channels -->
      <section aria-labelledby="channels-heading">
        <h2
          id="channels-heading"
          class="text-xl sm:text-2xl font-bold text-typo-primary mb-6"
        >
          {t("channels.title")}
        </h2>

        <ul class="space-y-4">
          <!-- Email -->
          <li>
            <a
              href="mailto:romerogonzaga21@gmail.com"
              class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-ui-01 border border-gray-200 dark:border-ui-02/50 hover:border-ui-accent/40 hover:shadow-md hover:shadow-ui-accent/5 transition-all duration-300 group"
            >
              <span
                class="flex-shrink-0 flex items-center justify-center w-11 h-11 rounded-xl bg-ui-accent/10 text-ui-accent text-xl group-hover:bg-ui-accent group-hover:text-white transition-colors duration-300"
              >
                <Icon name="tabler:mail" />
              </span>
              <div class="min-w-0">
                <p class="text-xs font-semibold text-typo-secondary uppercase tracking-wider mb-0.5">
                  {t("channels.email.label")}
                </p>
                <p class="text-sm sm:text-base font-medium text-typo-primary truncate">
                  {t("channels.email.value")}
                </p>
              </div>
              <Icon
                name="tabler:arrow-right"
                class="ml-auto text-typo-secondary group-hover:text-ui-accent group-hover:translate-x-1 transition-all duration-300 flex-shrink-0"
              />
            </a>
          </li>

          <!-- LinkedIn -->
          <li>
            <a
              href="https://www.linkedin.com/in/jhonromero26/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-ui-01 border border-gray-200 dark:border-ui-02/50 hover:border-ui-accent/40 hover:shadow-md hover:shadow-ui-accent/5 transition-all duration-300 group"
            >
              <span
                class="flex-shrink-0 flex items-center justify-center w-11 h-11 rounded-xl bg-ui-accent/10 text-ui-accent text-xl group-hover:bg-ui-accent group-hover:text-white transition-colors duration-300"
              >
                <Icon name="simple-icons:linkedin" />
              </span>
              <div class="min-w-0">
                <p class="text-xs font-semibold text-typo-secondary uppercase tracking-wider mb-0.5">
                  {t("channels.linkedin.label")}
                </p>
                <p class="text-sm sm:text-base font-medium text-typo-primary truncate">
                  {t("channels.linkedin.value")}
                </p>
              </div>
              <Icon
                name="tabler:arrow-right"
                class="ml-auto text-typo-secondary group-hover:text-ui-accent group-hover:translate-x-1 transition-all duration-300 flex-shrink-0"
              />
            </a>
          </li>

          <!-- GitHub -->
          <li>
            <a
              href="https://github.com/JhonRomero26"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-ui-01 border border-gray-200 dark:border-ui-02/50 hover:border-ui-accent/40 hover:shadow-md hover:shadow-ui-accent/5 transition-all duration-300 group"
            >
              <span
                class="flex-shrink-0 flex items-center justify-center w-11 h-11 rounded-xl bg-ui-accent/10 text-ui-accent text-xl group-hover:bg-ui-accent group-hover:text-white transition-colors duration-300"
              >
                <Icon name="simple-icons:github" />
              </span>
              <div class="min-w-0">
                <p class="text-xs font-semibold text-typo-secondary uppercase tracking-wider mb-0.5">
                  {t("channels.github.label")}
                </p>
                <p class="text-sm sm:text-base font-medium text-typo-primary truncate">
                  {t("channels.github.value")}
                </p>
              </div>
              <Icon
                name="tabler:arrow-right"
                class="ml-auto text-typo-secondary group-hover:text-ui-accent group-hover:translate-x-1 transition-all duration-300 flex-shrink-0"
              />
            </a>
          </li>

          <!-- CV -->
          <li>
            <a
              href={lang === "es" ? "/es/cv" : "/cv"}
              class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-ui-01 border border-gray-200 dark:border-ui-02/50 hover:border-ui-accent/40 hover:shadow-md hover:shadow-ui-accent/5 transition-all duration-300 group"
            >
              <span
                class="flex-shrink-0 flex items-center justify-center w-11 h-11 rounded-xl bg-ui-accent/10 text-ui-accent text-xl group-hover:bg-ui-accent group-hover:text-white transition-colors duration-300"
              >
                <Icon name="tabler:paperclip" />
              </span>
              <div class="min-w-0">
                <p class="text-xs font-semibold text-typo-secondary uppercase tracking-wider mb-0.5">
                  {t("channels.cv.label")}
                </p>
                <p class="text-sm sm:text-base font-medium text-typo-primary">
                  {t("channels.cv.value")}
                </p>
              </div>
              <Icon
                name="tabler:arrow-right"
                class="ml-auto text-typo-secondary group-hover:text-ui-accent group-hover:translate-x-1 transition-all duration-300 flex-shrink-0"
              />
            </a>
          </li>
        </ul>

        <!-- Primary CTA -->
        <div class="mt-8">
          <a
            href="mailto:romerogonzaga21@gmail.com"
            class="btn btn-primary w-full flex items-center justify-center gap-2 px-8 py-3 text-base font-semibold rounded-full shadow-lg shadow-ui-accent/20"
          >
            <Icon name="tabler:mail" />
            {t("cta.email")}
          </a>
        </div>
      </section>

      <!-- Opportunities -->
      <section aria-labelledby="opportunities-heading">
        <h2
          id="opportunities-heading"
          class="text-xl sm:text-2xl font-bold text-typo-primary mb-6"
        >
          {t("opportunities.title")}
        </h2>

        <ul class="space-y-4">
          {
            opportunities.map((item) => (
              <li class="p-5 rounded-xl bg-ui-01 dark:bg-ui-01 border border-ui-02 dark:border-ui-02/50 transition-shadow duration-300 hover:shadow-md dark:hover:shadow-none" style="box-shadow: var(--shadow-card);">
                <div class="flex items-start gap-3">
                  <div
                    class="flex-shrink-0 w-2 h-2 rounded-full mt-2"
                    style="background-color: var(--color-ui-accent);"
                    aria-hidden="true"
                  />
                  <div>
                    <h3 class="font-semibold text-typo-primary mb-1">{item.title}</h3>
                    <p class="text-sm sm:text-base text-typo-secondary leading-relaxed">
                      {item.description}
                    </p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
</Layout>
